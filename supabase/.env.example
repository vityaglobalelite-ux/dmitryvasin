# Secrets for Edge Functions (set via `supabase secrets set` or self-hosted env)

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Цены по умолчанию — в таблице tariff_prices (см. bot/sql/005_tariff_prices.sql).
# Env ниже только fallback, если строки в БД нет:
# STRIPE_CURRENCY=eur
# STRIPE_AMOUNT_TRIAL=4900
# STRIPE_PRICE_TRIAL=price_...

CHECKOUT_SECRET=same-as-bot-CHECKOUT_SECRET

# Usually injected by Supabase runtime:
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SUCCESS_URL=https://t.me/YOUR_BOT_USERNAME
STRIPE_CANCEL_URL=https://t.me/YOUR_BOT_USERNAME
